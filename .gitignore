# --- uv & Environments ---
# We ignore the virtual environment directory itself
.venv/
venv/
ENV/

# --- AI & Data Science ---
# Ignore large model files or local datasets
*.pt
*.pth
*.bin
*.pkl
*.h5
data/
models/
.ipynb_checkpoints/

# --- Environment Secrets (CRITICAL) ---
# This is where you will keep your API keys (OpenAI, Anthropic, etc.)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- PyCharm / IDEs ---
.idea/
.vscode/
*.swp
*.swo

# --- Logs ---
*.log
logs/

# Chainlit auto-generated assets and translation files
.chainlit/*
!.chainlit/config.toml
!.chainlit/translations/
.chainlit/translations/*
!.chainlit/translations/en-US.json

